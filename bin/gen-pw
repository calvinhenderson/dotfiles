#!/usr/bin/env sh

# WORD_LIST=/usr/share/dict/words
# WORD_LIST=~/Documents/safe_word_list.txt
WORD_COUNT=${WORD_COUNT:-3}
MIN_LENGTH=${MIN_LENGTH:-2}
MAX_LENGTH=${MAX_LENGTH:-4}
WORD_LIST="""
