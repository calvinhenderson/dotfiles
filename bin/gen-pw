get_word() {
  echo "$WORD_LIST" |
    sort -R |
    head -n1
}

rand() {
  seq $1 $2 | sort -R | head -n1
}

RAND_NUM_IDX=1
# RAND_NUM_IDX=$(rand 1 $WORD_COUNT)
RAND_NUM=$(rand 0 9)
# RAND_CAP_IDX=$(rand 1 $WORD_COUNT)

for i in $(seq 1 $WORD_COUNT); do
  if [ $i -eq $RAND_NUM_IDX ]; then
    PASSWORD="$PASSWORD$(printf '%d%s' $RAND_NUM $(get_word))"
  else
    PASSWORD="$PASSWORD$(printf '%s' $(get_word))"
  fi

  if [ $i -lt $WORD_COUNT ]; then
    PASSWORD="$PASSWORD-"
  fi
done

printf "$PASSWORD"
